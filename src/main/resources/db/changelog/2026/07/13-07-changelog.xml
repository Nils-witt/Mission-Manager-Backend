<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1789900500000-1" author="nilswitt">
        <createTable tableName="qualification">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_qualification"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="modified_by" type="VARCHAR(255)"/>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1789900500000-2" author="nilswitt">
        <createTable tableName="qualification_included_qualifications">
            <column name="qualification_id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_qualification_included_qualifications"/>
            </column>
            <column name="included_qualification_id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_qualification_included_qualifications"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1789900500000-3" author="nilswitt">
        <addForeignKeyConstraint baseColumnNames="qualification_id" baseTableName="qualification_included_qualifications"
                                  constraintName="fk_qualincqual_on_qualification" referencedColumnNames="id"
                                  referencedTableName="qualification" onDelete="CASCADE"/>
    </changeSet>
    <changeSet id="1789900500000-4" author="nilswitt">
        <addForeignKeyConstraint baseColumnNames="included_qualification_id"
                                  baseTableName="qualification_included_qualifications"
                                  constraintName="fk_qualincqual_on_included_qualification" referencedColumnNames="id"
                                  referencedTableName="qualification" onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>
